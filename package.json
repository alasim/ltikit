{
  "name": "ltikit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Runtime-, storage-, and framework-agnostic LTI 1.3 (LTI Advantage) toolkit.",
  "license": "MIT",
  "author": "alasim <alasim.mail@gmail.com> (https://github.com/alasim)",
  "homepage": "https://alasim.github.io/ltikit",
  "repository": {
    "type": "git",
    "url": "https://github.com/alasim/ltikit.git"
  },
  "bugs": "https://github.com/alasim/ltikit/issues",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" build",
    "typecheck": "pnpm --filter \"./packages/*\" typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=18"
  }
}
