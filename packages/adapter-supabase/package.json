{
  "name": "@ltikit/adapter-supabase",
  "version": "1.0.0-rc.0",
  "description": "Supabase/Postgres PlatformStore + NonceStore adapters for ltikit.",
  "license": "MIT",
  "author": "alasim <alasim.mail@gmail.com> (https://github.com/alasim)",
  "homepage": "https://alasim.github.io/ltikit/guides/supabase-adapter/",
  "repository": {
    "type": "git",
    "url": "https://github.com/alasim/ltikit.git",
    "directory": "packages/adapter-supabase"
  },
  "bugs": "https://github.com/alasim/ltikit/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "sql",
    "bin"
  ],
  "bin": {
    "ltikit-supabase-sql": "bin/print-sql.mjs"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ltikit/core": "workspace:*"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
