{
  "name": "@ltikit/core",
  "version": "1.0.0-rc.0",
  "description": "Runtime-agnostic LTI 1.3 (LTI Advantage) core — jose + fetch, no framework, no DB.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "jose": "^5.9.6"
  },
  "peerDependencies": {
    "vitest": "^2 || ^3"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
