{
  "name": "@ltikit/next",
  "version": "1.0.0-rc.0",
  "description": "Next.js App Router route-handler bindings for ltikit (Web-standard Request/Response — no next dependency).",
  "license": "MIT",
  "author": "alasim <alasim.mail@gmail.com> (https://github.com/alasim)",
  "homepage": "https://alasim.github.io/ltikit/guides/frameworks/",
  "repository": {
    "type": "git",
    "url": "https://github.com/alasim/ltikit.git",
    "directory": "packages/next"
  },
  "bugs": "https://github.com/alasim/ltikit/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ltikit/core": "workspace:*"
  },
  "devDependencies": {
    "jose": "^5.9.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
