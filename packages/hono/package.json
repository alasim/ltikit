{
  "name": "@ltikit/hono",
  "version": "1.0.0-rc.0",
  "description": "Hono route bindings for ltikit.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ltikit/core": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4"
  },
  "devDependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
