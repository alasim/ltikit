# Public base URL of THIS tool (no trailing slash), e.g. https://tool.ngrok.app
APP_URL=

# Supabase (service-role key — server only, never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY is the service_role JWT (decodes to role=service_role).
# In TeachSim this same value is named SUPABASE_API_SECRET_KEY. The anon key is
# not needed here — the adapter uses the service-role client only.
#
# The values below are the DEFAULTS for the bundled local Supabase (see
# supabase/config.toml, API on the shifted port 54421). They are the well-known
# local-dev keys — not secret. For a hosted project, replace both.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Tool signing keypair (RS256).
#   Generate: see README. LTI_TOOL_PRIVATE_KEY is PKCS8 PEM (\n-escaped is fine).
#   LTI_TOOL_PUBLIC_JWK is the matching public key as a JWK JSON string.
LTI_TOOL_KEY_ID=ltikit-key-1
LTI_TOOL_PRIVATE_KEY=
LTI_TOOL_PUBLIC_JWK=

# LMS origins allowed to embed the tool in an iframe (comma-separated).
LTI_PLATFORM_ORIGINS=https://canvas.instructure.com,https://your.moodlecloud.com
