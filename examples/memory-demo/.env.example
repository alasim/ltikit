# Public base URL of THIS tool (no trailing slash), e.g. https://tool.ngrok.app
APP_URL=

# Tool signing keypair (RS256).
#   Generate: see README. LTI_TOOL_PRIVATE_KEY is PKCS8 PEM (\n-escaped is fine).
#   LTI_TOOL_PUBLIC_JWK is the matching public key as a JWK JSON string.
LTI_TOOL_KEY_ID=ltikit-key-1
LTI_TOOL_PRIVATE_KEY=
LTI_TOOL_PUBLIC_JWK=

# LMS origins allowed to embed the tool in an iframe (CSP frame-ancestors).
# MUST include every LMS host that frames the tool, or the browser blocks the
# launch with a CSP error. Scheme + host only (NO trailing slash, NO path),
# comma-separated. Changing this requires a `next dev` / build restart.
LTI_PLATFORM_ORIGINS=https://your-moodle-site.com,https://canvas.instructure.com
